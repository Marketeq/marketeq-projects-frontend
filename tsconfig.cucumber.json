{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowJs": true,
    "noEmit": true
  },
  "exclude": [
    "node_modules",
    "archive",
    "stories",
    ".storybook",
    "**/*.stories.tsx",
    "**/*.stories.ts",
    "playwright.config.ts",
    "tests"
  ]
}
