# Environment
NEXT_PUBLIC_ENV=development

# Frontend app origin
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Gateway base (recommended single entrypoint)
NEXT_PUBLIC_API_URL=http://localhost:3002

# Service-specific frontend bases (currently routed via gateway)
NEXT_PUBLIC_AUTH_URL=http://localhost:3002
NEXT_PUBLIC_USER_URL=http://localhost:3002

# Legacy/utility clients used in parts of the app
NEXT_PUBLIC_BACKEND_URL=http://localhost:3002
NEXT_PUBLIC_API_BASE_URL=http://localhost:3002/api
NEXT_PUBLIC_FAVORITES_API_URL=http://localhost:3002/favorites
NEXT_PUBLIC_SEMANTIC_API_URL=http://localhost:3002

# Auth providers (public client IDs only)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=

# Optional UI/config values
NEXT_PUBLIC_PROJECT_SCOPE_TIP_VIDEO_URL=
NEXT_PUBLIC_IMAGE_QUALITY=0.85

# E2E/Test-only vars
PLAYWRIGHT_BASE_URL=http://localhost:3000
GOOGLE_TEST_EMAIL=
GOOGLE_TEST_PASSWORD=
REPORT_NAME=
DASHBOARD_HOLD_MS=0
